  <diagram id="FLo1Oje4nZHkchGrNvKe" name="第 4 页">
    <mxGraphModel dx="473" dy="263" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="1LVvzSUvabLW3t-Rm7qR-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Byte Pool" vertex="1">
          <mxGeometry height="40" width="120" x="120" y="120" as="geometry" />
        </mxCell>
        <mxCell id="1LVvzSUvabLW3t-Rm7qR-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="每次流程：&lt;div&gt;①先peek检查队列的size，如果大于4，那么这一次可取byte数对应1 2 4&lt;/div&gt;&lt;div&gt;②取数，不同的个数可以采用不同的策略&lt;/div&gt;&lt;div&gt;如果只有一个byte，那么只能8bit写&lt;/div&gt;&lt;div&gt;如果有两个byte，可以16bit写或8bit写两次&lt;/div&gt;&lt;div&gt;如果有四个byte，可以32、16+16、16+8+8、8+8+16、8+8+8+8这四种&lt;/div&gt;&lt;div&gt;重复执行，直到size中没有数据了&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="330" x="110" y="220" as="geometry" />
        </mxCell>
        <mxCell id="1LVvzSUvabLW3t-Rm7qR-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="结果寄存器读&lt;div&gt;如果是32bit模式，就用32bit读&lt;/div&gt;&lt;div&gt;如果是16bit模式，随机32bit读或16bit读&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="220" x="90" y="340" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
