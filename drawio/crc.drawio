        <mxCell id="QhEwIEfrcW2vCuTamlm8-60" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="CRC Tr&lt;div&gt;Subsrcriber&lt;/div&gt;" vertex="1">
          <mxGeometry height="40" width="80" x="622" y="171" as="geometry" />
        </mxCell>
        <mxCell id="QhEwIEfrcW2vCuTamlm8-63" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#cdeb8b;strokeColor=#36393d;" value="Data Send Seq" vertex="1">
          <mxGeometry height="30" width="120" x="439" y="338.5" as="geometry" />
        </mxCell>
        <mxCell id="QhEwIEfrcW2vCuTamlm8-64" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1. 基于寄存器模型管理寄存器，包括配置流与数据流&lt;/span&gt;&lt;div&gt;2. CRC Subscriber监听Vip Mon广播，捕获配置与结果，读数据完成Tr封装&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;3. byte流seq决定代校验数据，与配置封装到Tr包中&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;4.scoreboard比对配置包与校验结果，实际值为寄存器返回值，期望值为CRC Calc Engine计算值&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;5.配置与数据通过config_db从用例中传递&lt;/span&gt;&lt;/div&gt;&lt;div&gt;6.不同用例，继承/修改/约束，配置信息或配置流seq&lt;/div&gt;&lt;div&gt;7.CRC&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Calc Engine(SV)已通过开源Python版本CRC算法一致性检查&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="400" x="210" y="532" as="geometry" />
        </mxCell>
        <mxCell id="QhEwIEfrcW2vCuTamlm8-65" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="CRC 验证环境架构" vertex="1">
          <mxGeometry height="30" width="140" x="364" y="439" as="geometry" />
        </mxCell>
        <mxCell id="SC_5_cm7A5yWxtK14CPK-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="位宽" vertex="1">
          <mxGeometry height="22" width="77" x="204" y="637.5" as="geometry" />
        </mxCell>
        <mxCell id="SC_5_cm7A5yWxtK14CPK-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="数字/种子" vertex="1">
          <mxGeometry height="22" width="78" x="204" y="666.5" as="geometry" />
        </mxCell>
        <mxCell id="SC_5_cm7A5yWxtK14CPK-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="校验使能" vertex="1">
          <mxGeometry height="22" width="78" x="204" y="695.5" as="geometry" />
        </mxCell>
        <mxCell id="SC_5_cm7A5yWxtK14CPK-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="输入转置类型" vertex="1">
          <mxGeometry height="22" width="79" x="204" y="724.5" as="geometry" />
        </mxCell>
        <mxCell id="SC_5_cm7A5yWxtK14CPK-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="多项式" vertex="1">
          <mxGeometry height="22" width="79" x="204" y="785.5" as="geometry" />
        </mxCell>
        <mxCell id="SC_5_cm7A5yWxtK14CPK-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="DATA" vertex="1">
          <mxGeometry height="22" width="79" x="204" y="814.5" as="geometry" />
        </mxCell>
        <mxCell id="SC_5_cm7A5yWxtK14CPK-13" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;ul&gt;&lt;li&gt;监测总线操作&lt;/li&gt;&lt;li&gt;当写入CTRL寄存器时(读操作不关心)&lt;/li&gt;&lt;li&gt;将写入值更新到对应的CFG中&lt;/li&gt;&lt;li&gt;当写入多项式寄存器poly时，保存当前多项式到变量&lt;/li&gt;&lt;li&gt;读出多项式寄存器poly不关心。&lt;/li&gt;&lt;li&gt;当写入数据寄存器data时，且CFG中的WAS是1，即种子模式，此时更新seed变量，该变量为初始种子&lt;/li&gt;&lt;li&gt;当写入数据寄存器data时，且CFG中的WAS是0，即数据模式，此时将写入的数据，存到一个动态数组中(作为此轮校验的数据组)&lt;/li&gt;&lt;li&gt;当读取数据寄存器data时，将CFG/当前的动态数组/初始种子/多项式/结果值打包封装为Transaction&lt;/li&gt;&lt;li&gt;注:每次重新配置种子(即使相等)，都需要清除当前的动态数组。&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="30" width="352" x="279" y="722" as="geometry" />
        </mxCell>
        <mxCell id="QCGRmw7osLY-PluJX7OH-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="" vertex="1">
